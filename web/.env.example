# Frontend config — publishable values ONLY (docs/01 §2.1).
# The static bundle must never contain a secret. Names only here; real values
# go in .env.local (git-ignored) locally and in the Pages build env in CI.

# Base URL of the Railway API (all routes prefixed /api).
NEXT_PUBLIC_API_URL=

# Razorpay publishable key id (rzp_test_… / rzp_live_…). NOT the key secret.
NEXT_PUBLIC_RAZORPAY_KEY_ID=

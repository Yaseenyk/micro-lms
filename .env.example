# Names only — never commit real values. Config is validated at boot (docs/01 §2.1).

# --- API (Railway) ---
NODE_ENV=development
PORT=8080
MONGODB_URI=
JWT_SECRET=                 # >= 32 chars
JWT_EXPIRES_IN=15m
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
CORS_ORIGIN=               # the frontend origin, e.g. https://<user>.github.io

# --- Web (static, publishable only) ---
NEXT_PUBLIC_API_URL=       # the Railway API origin
NEXT_PUBLIC_RAZORPAY_KEY_ID=   # publishable key_id only, never the secret

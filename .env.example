# Names only — never commit real values. Config is validated at boot (docs/01 §2.1).

# --- API (Railway) ---
NODE_ENV=development
PORT=8080
MONGODB_URI=
JWT_SECRET=                 # >= 32 chars
JWT_EXPIRES_IN=15m
CORS_ORIGIN=               # the frontend origin, e.g. https://<user>.github.io

# Access model (docs/04 §0a). Defaults to true: every catalog course is open to
# any signed-in user, and the payment surface is not mounted.
FREE_ACCESS=true

# Payments — required ONLY when FREE_ACCESS=false. Left unset, the API boots
# free and never touches Razorpay.
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# --- Web (static, publishable only) ---
NEXT_PUBLIC_API_URL=       # the Railway API origin
